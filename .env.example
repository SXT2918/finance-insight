FLASK_SECRET_KEY=change-me
DATABASE_PATH=data/finance_insight.db

# Anthropic API for the AI research desk, daily brief, and paper-trading agent.
# Without this set, those features show a "not configured" state instead of
# calling out. News/prices come from yfinance and need no separate key.
ANTHROPIC_API_KEY=

# Cache/staleness thresholds (hours)
QUOTE_STALE_AFTER_HOURS=24
NEWS_STALE_AFTER_HOURS=24
